
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"

}

model User {
  id              String            @id @default(uuid())
  clerkId         String            @unique
  email           String            @unique
  firstName       String
  lastName        String
  avatarUrl       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  preferences          UserPreferences?
  enrollments          Enrollment[]
  topicCompletions     TopicCompletion[]
  chatMessages         ChatMessage[]
  objectiveCoverages   UserObjectiveCoverage[]
  streak               UserStreak?
  dailyActivities      DailyActivity[]
  quickConversations   QuickConversation[]
  subscription         Subscription?
  usageTrackers        UsageTracker[]
}

model UserPreferences {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  educationLevel       Int
  studySessionDuration Int
  learningGoal         String
  explanationDepth     Int
  interests            String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Course {
  id          String       @id @default(uuid())
  title       String
  description String
  color       String
  icon        String
  imageUrl    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  topics      Topic[]
  enrollments Enrollment[]
}

model Topic {
  id           String              @id @default(uuid())
  courseId     String
  course       Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  order        Int
  overview     String?
  createdAt    DateTime            @default(now())
  completions  TopicCompletion[]
  chatMessages ChatMessage[]
  objectives   LearningObjective[]

  @@unique([courseId, order])
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
}

model TopicCompletion {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, topicId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([userId, topicId])
}

model LearningObjective {
  id        String                  @id @default(uuid())
  topicId   String
  topic     Topic                   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  text      String
  order     Int
  createdAt DateTime                @default(now())
  covered   UserObjectiveCoverage[]

  @@unique([topicId, order])
}

model UserObjectiveCoverage {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  objectiveId String
  objective   LearningObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  coveredAt   DateTime          @default(now())

  @@unique([userId, objectiveId])
}

model UserStreak {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  totalXp          Int      @default(0)
  dailyXp          Int      @default(0)
  dailyXpGoal      Int      @default(200)
  lastActivityDate String?
  daysAtTop        Int      @default(0)
  milestoneReached Int?
  updatedAt        DateTime @updatedAt

  @@index([totalXp(sort: Desc)])
}

model DailyActivity {
  id                 String  @id @default(uuid())
  userId             String
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  date               String
  chatMessageAwarded Boolean @default(false)

  @@unique([userId, date])
  @@index([userId])
}

model QuickConversation {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  messages  QuickChatMessage[]

  @@index([userId])
}

model QuickChatMessage {
  id             String            @id @default(uuid())
  conversationId String
  conversation   QuickConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime          @default(now())

  @@index([conversationId])
}

model Subscription {
  id                       String    @id @default(uuid())
  userId                   String    @unique
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                     String    @default("free")
  interval                 String?
  currency                 String?
  status                   String    @default("active")
  paystackCustomerCode     String?   @unique
  paystackSubscriptionCode String?   @unique
  paystackEmailToken       String?
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelledAt              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model UsageTracker {
  id           String @id @default(uuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         String
  chatMessages Int    @default(0)
  quizzes      Int    @default(0)

  @@unique([userId, date])
}
